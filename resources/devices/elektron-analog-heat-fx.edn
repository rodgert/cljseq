;;
;; Elektron Analog Heat +FX — cljseq device map
;;
;; Sources:
;;   Elektron Analog Heat +FX User Manual OS1.01:
;;     https://www.elektron.se/wp-content/uploads/2024/09/Analog_Heat_FX_User_Manual_ENG_OS1.01_240325.pdf
;; Confidence: High.
;;
;; Architecture overview:
;;   - Mono/stereo analog distortion and filter unit (Heat section)
;;   - 8 analog circuit modes (Clean Boost, Saturation, Enhancement, Clip, Fold,
;;     Fuzz, Medium Overdrive, High Overdrive)
;;   - Multimode analog filter (14 modes) with self-oscillation and pre-drive
;;   - 3-band EQ; Envelope follower; 3 LFOs; 2 CV/expression inputs
;;   - Gate (noise gate)
;;   - Dual digital FX section (separate MIDI channel):
;;     Bits (SRR/BR), Chorus, Delay, Reverb, Compressor, Warble, Bass Focus
;;
;; Dual MIDI channel architecture (critical):
;;   - MIDI CHANNEL (MAIN): receives CC and NRPN for the Heat section
;;     (Character, EQ, Filter, Envelope, LFO 1–3, Controls, Gate, Preset Volume)
;;   - FX MIDI CHANNEL:    receives CC and NRPN for the FX section
;;     (Bits, Chorus, Delay, Reverb, Compressor, Warble, Bass Focus)
;;   Both channels are user-configurable in MIDI › CHANNELS (manual §6.6.3).
;;   OS 1.01 release notes: bug fixed where only default MIDI channels worked.
;;
;; CC annotation:
;;   :midi-context :main  — send to MIDI CHANNEL (Heat section)
;;   :midi-context :fx    — send to FX MIDI CHANNEL (FX section)
;;
;; 14-bit CCs: :cc-lsb is the paired LSB CC (typically MSB + 32).
;;   Max value 16256 or 16320 in the manual reflects 14-bit precision.
;;   In this map :range shows [0 127] for 7-bit and [0 16383] for 14-bit entries.
;;
;; Default values: not published by Elektron.

{:device/id           :elektron/analog-heat-fx
 :device/name         "Elektron Analog Heat +FX"
 :device/manufacturer "Elektron Music Machines"
 :device/type         :effects-processor
 :device/voices       1
 :device/role         :target
 :device/connectivity [:usb-midi :din-midi]

 ;; -------------------------------------------------------------------------
 ;; MIDI channel — dual-channel architecture; both user-configurable
 ;; -------------------------------------------------------------------------
 :midi/channel        {:main 1    ; Heat section (Character, Filter, EQ, Env, LFOs, Gate)
                        :fx   2}   ; FX section (Bits, Chorus, Delay, Reverb, Compressor, Warble, Bass Focus)

 ;; -------------------------------------------------------------------------
 ;; Clock
 ;; -------------------------------------------------------------------------
 :midi/clock
 {:receive true
  :send    true
  :uses    [:lfo-sync]}

 ;; -------------------------------------------------------------------------
 ;; Program change
 ;; -------------------------------------------------------------------------
 :midi/program-change
 {:receive true
  :send    true
  :range   [0 127]
  :bank-select false}

 ;; -------------------------------------------------------------------------
 ;; SysEx
 ;; -------------------------------------------------------------------------
 :midi/sysex
 {:manufacturer-id [0x00 0x20 0x3C]   ; Elektron Music Machines AB (shared by all Elektron devices)
  :purpose         [:patch-dump :patch-load :firmware-update]
  :note "SysEx format not publicly documented; use Elektron Transfer application"}

 ;; -------------------------------------------------------------------------
 ;; Control Change map
 ;;
 ;; :midi-context :main — send to MIDI CHANNEL (Heat section)
 ;; :midi-context :fx   — send to FX MIDI CHANNEL (digital FX section)
 ;;
 ;; 14-bit entries have :cc-lsb (LSB CC = MSB + 32 convention).
 ;; -------------------------------------------------------------------------
 :midi/cc

 [;; === HEAT SECTION (MAIN MIDI CHANNEL) ====================================

  ;; --- Character (circuit / drive / level / mix) ---------------------------
  {:cc 108 :path [:character :circuit]  :range [0 7]    :default :unknown :cc-type :fixed :midi-context :main
   :values [{:value 0 :label :clean-boost}
            {:value 1 :label :saturation}
            {:value 2 :label :enhancement}
            {:value 3 :label :clip}
            {:value 4 :label :fold}
            {:value 5 :label :fuzz}
            {:value 6 :label :medium-overdrive}
            {:value 7 :label :high-overdrive}]}
  {:cc 109 :path [:character :drive]    :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 37}
  {:cc 110 :path [:character :level]    :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 39}
  {:cc 111 :path [:character :mix]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 40}

  ;; --- EQ ------------------------------------------------------------------
  {:cc 28  :path [:eq :low]             :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 41}
  {:cc 29  :path [:eq :high]            :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 42}

  ;; --- Filter --------------------------------------------------------------
  {:cc 30  :path [:filter :mode]        :range [0 13]   :default :unknown :cc-type :fixed :midi-context :main
   :note "14 filter modes (0–13)"}
  {:cc 22  :path [:filter :frequency]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 43}
  {:cc 26  :path [:filter :freq-pan]    :range [0 127]  :default 64  :cc-type :fixed :midi-context :main :cc-lsb 47
   :bipolar true :center 64}
  {:cc 23  :path [:filter :resonance]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 44}
  {:cc 27  :path [:filter :dirt]        :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 24  :path [:filter :env-amount]  :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 45}
  {:cc 25  :path [:filter :lfo1-amount] :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 46}

  ;; --- Envelope ------------------------------------------------------------
  {:cc 17  :path [:envelope :mode]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 13  :path [:envelope :attack]    :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 14  :path [:envelope :release]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 12  :path [:envelope :trig-level] :range [0 127] :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 32}
  {:cc 15  :path [:envelope :base]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 16  :path [:envelope :width]     :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 18  :path [:envelope :destination]  :range [0 112] :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 19  :path [:envelope :depth]     :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main :cc-lsb 33}
  {:cc 20  :path [:envelope :destination-2] :range [0 112] :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 21  :path [:envelope :depth-2]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}

  ;; --- LFO 1 ---------------------------------------------------------------
  {:cc 66  :path [:lfo 1 :waveform]     :range [0 6]    :default :unknown :cc-type :fixed :midi-context :main
   :note "7 waveforms (0–6)"}
  {:cc 70  :path [:lfo 1 :mode]         :range [0 4]    :default :unknown :cc-type :fixed :midi-context :main
   :note "5 modes (0–4)"}
  {:cc 67  :path [:lfo 1 :speed]        :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 68  :path [:lfo 1 :multiplier]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 69  :path [:lfo 1 :fade]         :range [0 127]  :default 64  :cc-type :fixed :midi-context :main
   :bipolar true :center 64}
  {:cc 71  :path [:lfo 1 :start-phase]  :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 72  :path [:lfo 1 :destination]  :range [0 112]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 73  :path [:lfo 1 :depth]        :range [0 127]  :default 64  :cc-type :fixed :midi-context :main :cc-lsb 34
