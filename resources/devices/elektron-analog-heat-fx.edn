 ;; NRPN MSB = 1 → Heat section (received on MAIN MIDI CHANNEL)
 ;; NRPN MSB = 2 → FX section   (received on FX MIDI CHANNEL)
 ;; -------------------------------------------------------------------------
 :midi/nrpn

 [;; === NRPN MSB 1: Heat section (MAIN MIDI CHANNEL) ========================

  ;; Envelope
  {:nrpn [1 12]  :path [:envelope :trig-level]   :range [0 16383] :midi-context :main}
  {:nrpn [1 13]  :path [:envelope :attack]        :range [0 127]  :midi-context :main}
  {:nrpn [1 14]  :path [:envelope :release]       :range [0 127]  :midi-context :main}
