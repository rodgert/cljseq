  {:cc 75  :path [:lfo 1 :depth-2]      :range [0 127]  :default 64  :cc-type :fixed :midi-context :main
   :bipolar true :center 64}

  ;; --- LFO 2 ---------------------------------------------------------------
  {:cc 76  :path [:lfo 2 :waveform]     :range [0 6]    :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 80  :path [:lfo 2 :mode]         :range [0 4]    :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 77  :path [:lfo 2 :speed]        :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 78  :path [:lfo 2 :multiplier]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 79  :path [:lfo 2 :fade]         :range [0 127]  :default 64  :cc-type :fixed :midi-context :main
   :bipolar true :center 64}
  {:cc 81  :path [:lfo 2 :start-phase]  :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 82  :path [:lfo 2 :destination]  :range [0 112]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 83  :path [:lfo 2 :depth]        :range [0 127]  :default 64  :cc-type :fixed :midi-context :main :cc-lsb 35
   :bipolar true :center 64}
  {:cc 84  :path [:lfo 2 :destination-2] :range [0 112] :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 85  :path [:lfo 2 :depth-2]      :range [0 127]  :default 64  :cc-type :fixed :midi-context :main
