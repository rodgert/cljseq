  {:cc 13  :path [:reverb :decay-time]  :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 14  :path [:reverb :frequency]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 15  :path [:reverb :gain]        :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 16  :path [:reverb :highpass]    :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 17  :path [:reverb :lowpass]     :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 18  :path [:reverb :amount]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 19  :path [:reverb :mode]        :range [0 2]    :default :unknown :cc-type :fixed :midi-context :fx
