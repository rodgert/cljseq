  {:cc 101 :path [:cv-a :depth]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 102 :path [:expr-a :destination] :range [0 112]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 103 :path [:expr-a :depth]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 104 :path [:cv-b :destination]   :range [0 112]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 105 :path [:cv-b :depth]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 106 :path [:expr-b :destination] :range [0 112]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 107 :path [:expr-b :depth]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}

  ;; --- Gate ----------------------------------------------------------------
  {:cc 113 :path [:gate :threshold]     :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 114 :path [:gate :hold]          :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 115 :path [:gate :release]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}
  {:cc 116 :path [:gate :range]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}

  ;; --- Preset Volume -------------------------------------------------------
  {:cc 112 :path [:preset :volume]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :main}

  ;; === FX SECTION (FX MIDI CHANNEL) ========================================

  ;; --- Bits (sample-rate and bit-depth reduction) --------------------------
  {:cc 88  :path [:bits :srr]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx
   :note "SRR = Sample Rate Reduction"}
  {:cc 89  :path [:bits :br]            :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx
   :note "BR = Bit Reduction"}
  {:cc 90  :path [:bits :filter]        :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 91  :path [:bits :mix]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}

  ;; --- Chorus --------------------------------------------------------------
  {:cc 102 :path [:chorus :depth]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx :cc-lsb 36}
  {:cc 103 :path [:chorus :speed]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx :cc-lsb 37}
  {:cc 105 :path [:chorus :width]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}
  {:cc 106 :path [:chorus :mix]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx}

  ;; --- Delay ---------------------------------------------------------------
  {:cc 107 :path [:delay :time]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :fx :cc-lsb 39}
