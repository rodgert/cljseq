  {:cc 25  :path [:filter :env-depth]     :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track :cc-lsb 57}
  {:cc 43  :path [:filter-eg :delay]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
