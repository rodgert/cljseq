;;
;; Elektron Digitone — cljseq device map
;;
;; Sources:
;;   Elektron Digitone User Manual OS1.41:
;;     https://www.elektron.se/wp-content/uploads/2024/09/Digitone_User_Manual_ENG_OS1.41_231108.pdf
;;   pencilresearch/midi CC dataset (cross-validation, CC-BY-SA 4.0):
;;     https://github.com/pencilresearch/midi/tree/main/Elektron
;; Confidence: High.
;;
;; Architecture overview:
;;   - 8-voice FM synthesizer; 4 sound tracks + 4 MIDI tracks
;;   - FM engine: 4 operators in two groups (A+B), 8 algorithms
;;   - Each operator has independent FM envelope and operator level
;;   - Per-track FX sends (Chorus, Delay, Reverb)
;;   - Global Chorus, Delay, Reverb, and Master section
;;
;; MIDI channel architecture (critical — differs from all other device types):
;;   - Each sound track has its own MIDI channel (typically tracks 1–4 = ch 1–4)
;;   - An AUTO CHANNEL (configurable) always addresses the currently selected track
;;   - FX and Master parameters are received on the AUTO CHANNEL only
;;   - Synth, Filter, Amp, LFO parameters are received on the track's own channel
;;   - Track channels and AUTO CHANNEL are all configurable in SETTINGS › MIDI › CHANNELS
;;
;; CC context annotation:
;;   :midi-context :track  — send to the individual sound track's MIDI channel
;;   :midi-context :auto   — send to the AUTO CHANNEL (FX/Master parameters)
;;   :midi-context :global — standard MIDI global messages (any channel)
;;
;; Key caveats:
;;   - Parameter locks on sequencer tracks do NOT transmit CC externally on playback.
;;     CC is only emitted when a knob is physically moved. Use MIDI tracks with CC1–CC8
;;     assignments to sequence external CC values.
;;   - Default values are not published by Elektron; :default :unknown throughout.
;;     Load an init preset and observe transmitted CC values to determine defaults.
;;   - 14-bit CC pairs follow the standard MSB + 32 = LSB convention throughout.
;;   - MIDI tracks have user-assignable CC destinations (CC val 1–8 = CCs 70–77);
;;     these are not synthesis parameters and are not in this map.
;;   - SysEx manufacturer ID 0x00 0x20 0x3C is shared by all Elektron devices.

{:device/id           :elektron/digitone
 :device/name         "Elektron Digitone"
 :device/manufacturer "Elektron Music Machines"
 :device/type         :synthesizer
 :device/voices       8
 :device/role         :target
 :device/connectivity [:usb-midi :din-midi]

 ;; -------------------------------------------------------------------------
 ;; MIDI channel — see architecture notes above
 ;; -------------------------------------------------------------------------
 :midi/channel        {:track-default [1 2 3 4]   ; tracks 1–4; user-configurable
                        :auto          9}           ; AUTO CHANNEL; user-configurable

 :midi/poly-mode      :poly

 ;; -------------------------------------------------------------------------
 ;; Notes
 ;; -------------------------------------------------------------------------
 :midi/notes
 {:range      [0 127]
  :velocity   {:note-on true :note-off false}
  :aftertouch {:channel-pressure true :poly-key-pressure false}}

 ;; -------------------------------------------------------------------------
 ;; Pitch bend
 ;; -------------------------------------------------------------------------
 :midi/pitch-bend
 {:default-semitones 2
  :configurable true}

 ;; -------------------------------------------------------------------------
 ;; Clock
 ;; -------------------------------------------------------------------------
 :midi/clock
 {:receive true
  :send    true
  :uses    [:lfo-sync :arpeggiator :sequencer]}

 ;; -------------------------------------------------------------------------
 ;; Program change
 ;; -------------------------------------------------------------------------
 :midi/program-change
 {:receive    true
  :send       true
  :range      [0 127]
  :bank-select false}

 ;; -------------------------------------------------------------------------
 ;; SysEx
 ;; -------------------------------------------------------------------------
 :midi/sysex
 {:manufacturer-id [0x00 0x20 0x3C]   ; Elektron Music Machines AB (shared by all Elektron devices)
  :purpose         [:patch-dump :patch-load :firmware-update]
  :note "SysEx format not publicly documented; use Elektron Transfer application"}

 ;; -------------------------------------------------------------------------
 ;; Control Change map
 ;;
 ;; :midi-context :track — send to the individual track's MIDI channel
 ;; :midi-context :auto  — send to the AUTO CHANNEL (FX/Master parameters)
 ;;
 ;; 14-bit CC pairs: :cc-lsb lists the paired LSB CC (MSB + 32 convention).
 ;; 14-bit max is 16383; 7-bit max is 127.
 ;; -------------------------------------------------------------------------
 :midi/cc

 [;; --- Standard ------------------------------------------------------------
  {:cc 1   :path [:mod-wheel]             :range [0 127]  :cc-type :global}
  {:cc 64  :path [:sustain]               :range [0 127]  :cc-type :global}
  {:cc 66  :path [:sostenuto]             :range [0 127]  :cc-type :global}

  ;; --- Trig parameters (on track channel) ----------------------------------
  {:cc 3   :path [:trig :root]            :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 4   :path [:trig :velocity]        :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 5   :path [:trig :length]          :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 13  :path [:trig :filter-trig]     :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 14  :path [:trig :lfo-trig]        :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 15  :path [:trig :portamento-time] :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 16  :path [:trig :portamento-on]   :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}

  ;; --- FM Syn 1: Algorithm and operator ratios (on track channel) ----------
  ;; CC 90/91/92 are 7-bit; CC 16–20 are 14-bit (MSB + 32 = LSB)
  {:cc 90  :path [:fm :algorithm]         :range [0 7]    :default :unknown :cc-type :fixed :midi-context :track
   :note "8 algorithms (0–7)"}
  {:cc 91  :path [:fm :ratio-c]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 92  :path [:fm :ratio-a]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 16  :path [:fm :ratio-b]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track :cc-lsb 48}
  {:cc 17  :path [:fm :harmonics]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track :cc-lsb 49}
  {:cc 18  :path [:fm :detune]            :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track :cc-lsb 50}
  {:cc 19  :path [:fm :feedback]          :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track :cc-lsb 51}
  {:cc 20  :path [:fm :mix]               :range [0 127]  :default 64  :cc-type :fixed :midi-context :track :cc-lsb 52
   :bipolar true :center 64}

  ;; --- FM Syn 2: Operator envelopes (on track channel) ---------------------
  ;; Operator A = carrier; Operator B = modulator
  {:cc 75  :path [:op-a :env-attack]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 76  :path [:op-a :env-decay]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 77  :path [:op-a :env-end]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 78  :path [:op-a :level]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 83  :path [:op-a :delay]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 84  :path [:op-a :trig]            :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 85  :path [:op-a :env-reset]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 79  :path [:op-b :env-attack]      :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 80  :path [:op-b :env-decay]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 81  :path [:op-b :env-end]         :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 82  :path [:op-b :level]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 86  :path [:op-b :delay]           :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 87  :path [:op-b :trig]            :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 88  :path [:op-b :env-reset]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}
  {:cc 89  :path [:fm :phase-reset]       :range [0 127]  :default :unknown :cc-type :fixed :midi-context :track}

  ;; --- Filter (on track channel) -------------------------------------------
