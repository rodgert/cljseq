{:synth/id   :supersaw
 :synth/tags [:saw :pad :dense :pitched]
 :synth/doc  "Seven detuned sawtooth oscillators — thick unison pad.
  :spread controls the total detune range in cents across all voices."
 :args  {:freq    440
         :amp     0.3
         :attack  0.3
         :decay   0.1
         :sustain 0.8
         :release 2.0
         :spread  20.0
