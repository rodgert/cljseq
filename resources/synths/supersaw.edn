                      [:saw [:* :freq [:+ 1.0 [:/ [:* :spread 0.28] 100.0]]]]
                      [:saw [:* :freq [:- 1.0 [:/ [:* :spread 0.14] 100.0]]]]
                      [:saw [:* :freq [:- 1.0 [:/ [:* :spread 0.28] 100.0]]]]
                      [:saw [:* :freq [:+ 1.0 [:/ [:* :spread 0.42] 100.0]]]]
                      [:saw [:* :freq [:- 1.0 [:/ [:* :spread 0.42] 100.0]]]]]]]
           :pan]]}
