{:synth/id   :dtri
 :synth/tags [:triangle :detuned :pitched]
 :synth/doc  "Two detuned triangle oscillators — Sonic-Pi :dtri equivalent.
  :detune is Hz spread across both voices. Warmer and softer than :dsaw."
 :args  {:freq    440
         :amp     0.5
         :detune  0.1
         :attack  0.01
         :decay   0.1
         :sustain 0.8
         :release 1.0
         :pan     0.0}
 :graph [:out 0
          [:pan2
           [:* [:env-gen [:adsr :attack :decay :sustain :release] :gate :amp]
               [:mix [[:lf-tri [:+ :freq [:* :detune 0.5]]]
                      [:lf-tri [:- :freq [:* :detune 0.5]]]]]]
           :pan]]}
